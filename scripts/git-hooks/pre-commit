#!/bin/sh
# ─────────────────────────────────────────────────────────────
# Pre-commit hook — detecta secrets en los archivos staged
#
# Instalar: npm run hooks:install  (o manualmente:
#   cp scripts/git-hooks/pre-commit .git/hooks/pre-commit
#   chmod +x .git/hooks/pre-commit)
#
# Saltarse UNA vez (emergencia): git commit --no-verify
# ─────────────────────────────────────────────────────────────

# Windows/macOS compat: re-exec con bash si no estamos en bash ya.
# Si bash no está disponible, dejamos pasar el commit con advertencia.
if [ -z "$BASH_VERSION" ]; then
  _bash="$(command -v bash 2>/dev/null)"
  if [ -n "$_bash" ]; then
    exec "$_bash" "$0" "$@"
  fi
  echo "⚠ bash no encontrado — saltando chequeo de secrets"
  exit 0
fi

set -e

RED='\033[0;31m'
YELLOW='\033[1;33m'
GREEN='\033[0;32m'
NC='\033[0m'

# Patrones de secrets conocidos — cada entrada = "nombre:regex"
# Diseñado para ser rápido y con pocos falsos positivos.
PATTERNS=(
  "Supabase PAT:sbp_[a-f0-9]{40,}"
  "Google API Key:AIza[0-9A-Za-z_-]{35,}"
  "Anthropic API Key:sk-ant-[a-zA-Z0-9_-]{90,}"
  "OpenAI API Key:sk-(proj-)?[a-zA-Z0-9_-]{40,}"
  "Apify Token:apify_api_[A-Za-z0-9]{36,}"
  "Supabase Service Role JWT:eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9[A-Za-z0-9_.-]+\\.[A-Za-z0-9_-]{40,}.*service_role"
  "AWS Access Key ID:AKIA[0-9A-Z]{16}"
  "Private Key Block:BEGIN (RSA |EC |DSA |OPENSSH )?PRIVATE KEY"
  "GitHub Token:gh[ps]_[A-Za-z0-9]{36,}"
  "Meta App Secret:(\"|')?meta_app_secret(\"|')?\\s*[:=]\\s*(\"|')[a-f0-9]{32}"
)

# Archivos exentos por path — tests, ejemplos, docs
EXEMPT_PATHS=(
  "scripts/git-hooks/"
  ".env.example"
  "docs/"
)

# Helpers
is_exempt() {
  local file="$1"
  for path in "${EXEMPT_PATHS[@]}"; do
    if [[ "$file" == *"$path"* ]]; then
      return 0
    fi
  done
  return 1
}

FOUND=0

# Staged files (solo added/modified, no deleted)
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [ -z "$STAGED_FILES" ]; then
  exit 0
fi

for file in $STAGED_FILES; do
  [ ! -f "$file" ] && continue
  is_exempt "$file" && continue

  # Leer staged version (no working dir)
  CONTENT=$(git show ":$file" 2>/dev/null || true)
  [ -z "$CONTENT" ] && continue

  for pattern in "${PATTERNS[@]}"; do
    name="${pattern%%:*}"
    regex="${pattern#*:}"

    if echo "$CONTENT" | grep -E -q "$regex"; then
      if [ "$FOUND" -eq 0 ]; then
        echo -e "${RED}✗ SECRETO DETECTADO en archivos staged${NC}"
        echo ""
      fi
      echo -e "${RED}  [$name] en:${NC} $file"
      FOUND=1
    fi
  done
done

if [ "$FOUND" -eq 1 ]; then
  echo ""
  echo -e "${YELLOW}Commit bloqueado. Opciones:${NC}"
  echo "  1. Mover el valor a .env.local / Vercel env vars / Supabase Vault"
  echo "  2. Si es un falso positivo, editá scripts/git-hooks/pre-commit"
  echo "  3. Para saltar (NO recomendado): git commit --no-verify"
  echo ""
  exit 1
fi

echo -e "${GREEN}✓ Sin secrets detectados en staged files${NC}"
exit 0
