# ═══════════════════════════════════════════════════════════════
# ARKO — Variables de Entorno
# ═══════════════════════════════════════════════════════════════
# Copiar este archivo como .env.local y completar los valores
# NUNCA commitear .env.local al repositorio
# Variables con sufijo OPTIONAL solo se completan si esa feature se usa
# ═══════════════════════════════════════════════════════════════

# ─── Supabase ───
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url_here
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key_here

# ─── OpenAI (optional según feature) ───
OPENAI_API_KEY=your_openai_api_key_here

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Meta OAuth (optional según feature) ───
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_REDIRECT_URI=http://localhost:3000/api/v1/auth/meta/callback

# ─── Meta Tokens Encryption ───
META_TOKENS_ENCRYPTION_KEY=your_encryption_key_here_min_32_chars

# ─── Apify Reel Enrichment (optional según feature) ───
APIFY_API_TOKEN=apify_api_your_token_here

# ─── Gemini AI (optional según feature) ───
GEMINI_API_KEY=your_gemini_api_key_here

# ─── YouTube API (optional según feature) ───
YOUTUBE_API_KEY=your_youtube_api_key_here
