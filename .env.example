#     SERVICE ROLE KEY:  eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6InpwaHZyb2hvc2l6a2Jybnh0cHBqIiwicm9sZSI6InNlcnZpY2Vfcm9sZSIsImlhdCI6MTc3NDIyNjgxOCwiZXhwIjoyMDg5ODAyODE4fQ.pq4rdGlsGYPHG37ViVpYwNjBW5YNz7JErqEXCiTHkWU
#
# Para local, usar los valores de Dev Arko:
NEXT_PUBLIC_SUPABASE_URL=https://hrsvglgswatwklivkoyp.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.eyJpc3MiOiJzdXBhYmFzZSIsInJlZiI6Imhyc3ZnbGdzd2F0d2tsaXZrb3lwIiwicm9sZSI6ImFub24iLCJpYXQiOjE3NzQyODE2NTgsImV4cCI6MjA4OTg1NzY1OH0.A5q2JZ21gWdz0claQ37IWFeKjVLNmgA8cAdHAWYNV9w
SUPABASE_SERVICE_ROLE_KEY=your_dev_arko_service_role_key_here

# ─── Meta OAuth (opcional — solo si trabajás con Instagram/Ads) ───
# META_REDIRECT_URI ya no se configura aquí.
# Se deriva automáticamente de NEXT_PUBLIC_APP_URL + /api/v1/auth/meta/callback
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_TOKENS_ENCRYPTION_KEY=your_encryption_key_here_min_32_chars

# ─── OpenAI (opcional — solo si trabajás con análisis IA) ───
OPENAI_API_KEY=your_openai_api_key_here

# ─── Gemini AI (opcional — solo si trabajás con análisis de video) ───
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Apify (opcional — solo si trabajás con enriquecimiento de Reels) ───
APIFY_API_TOKEN=apify_api_your_token_here

# ─── YouTube API (opcional — solo si trabajás con YouTube Intelligence) ───
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Background Sync (producción — Vercel Cron) ───
# Secret para autenticar el cron job de sincronización automática.
# Generá uno con: openssl rand -hex 32
# Configurar en Vercel: Settings → Environment Variables → CRON_SECRET
CRON_SECRET=

# ─── Supabase MCP (opcional — para que la IA consulte la DB directo) ───
# Se obtiene en: Supabase → Account → Access Tokens → Generate new token
# Usado por .mcp.json para conectar Claude Code a Supabase
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here
