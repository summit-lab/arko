# ═══════════════════════════════════════════════════════════════
# ARKO — Variables de Entorno
# ═══════════════════════════════════════════════════════════════
# 1. Copiar este archivo como .env.local
# 2. Completar los valores reales del ambiente
# 3. NUNCA commitear .env.local al repositorio
#
# Guía completa: docs/05-environments-guide.md
# ═══════════════════════════════════════════════════════════════

# ─── Ambiente (OBLIGATORIA) ───
# Valores posibles: local | staging | production
APP_ENV=local

# ─── App (OBLIGATORIA) ───
# URL base pública de la app. Cambia según ambiente.
#   local:      http://localhost:3000
#   staging:    https://staging.tudominio.com
#   production: https://app.tudominio.com
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Supabase (OBLIGATORIAS) ───
# Cada ambiente apunta a su propio proyecto Supabase:
#
#   local / staging → Dev Arko (hrsvglgswatwklivkoyp, us-west-2)
#   production      → Prod Arko (zphvrohosizkbrnxtppj, us-east-2)
#
# Obtener las keys desde: https://supabase.com/dashboard/project/<PROJECT_REF>/settings/api
# NUNCA hardcodear keys reales en este archivo — solo placeholders.
NEXT_PUBLIC_SUPABASE_URL=https://your_project_ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key_here
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here

# ─── Meta OAuth (opcional — solo si trabajás con Instagram/Ads) ───
# META_REDIRECT_URI ya no se configura aquí.
# Se deriva automáticamente de NEXT_PUBLIC_APP_URL + /api/v1/auth/meta/callback
META_APP_ID=your_meta_app_id_here
META_APP_SECRET=your_meta_app_secret_here
META_TOKENS_ENCRYPTION_KEY=your_encryption_key_here_min_32_chars

# ─── Instagram Webhooks (opcional — solo si activás DM tracking) ───
# IG_APP_SECRET: típicamente igual a META_APP_SECRET (Meta usa un único
#   app secret para OAuth + firma de webhooks). Declarado aparte por la
#   especificación del Sprint B.
# IG_WEBHOOK_VERIFY_TOKEN: string largo y aleatorio. Se copia también en el
#   dashboard de Meta App → Webhooks → Edit subscription → Verify token.
#   Generá uno con: openssl rand -hex 32
IG_APP_SECRET=your_meta_app_secret_here
IG_WEBHOOK_VERIFY_TOKEN=your_webhook_verify_token_here

# ─── Anthropic (opcional — Arko AI agente principal) ───
ANTHROPIC_API_KEY=your_anthropic_api_key_here

# ─── OpenAI (opcional — Arko AI respuestas simples) ───
OPENAI_API_KEY=your_openai_api_key_here

# ─── Gemini AI (opcional — solo si trabajás con análisis de video) ───
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Apify (opcional — solo si trabajás con enriquecimiento de Reels) ───
APIFY_API_TOKEN=apify_api_your_token_here

# ─── Sync Secret (obligatoria — autentica llamadas a Supabase Edge Functions) ───
# Generá un string random: openssl rand -hex 32
SYNC_SECRET=your_sync_secret_here

# ─── YouTube API (opcional — solo si trabajás con YouTube Intelligence) ───
YOUTUBE_API_KEY=your_youtube_api_key_here

# ─── Background Sync (producción — Vercel Cron) ───
# Secret para autenticar el cron job de sincronización automática.
# Generá uno con: openssl rand -hex 32
# Configurar en Vercel: Settings → Environment Variables → CRON_SECRET
CRON_SECRET=

# ─── Supabase MCP (opcional — para que la IA consulte la DB directo) ───
# Se obtiene en: Supabase → Account → Access Tokens → Generate new token
# Usado por .mcp.json para conectar Claude Code a Supabase
SUPABASE_ACCESS_TOKEN=your_supabase_access_token_here
